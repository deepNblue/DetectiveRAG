# API密钥配置（示例文件）
# 复制此文件为 api_keys.yaml 并填入真实密钥

# OpenAI API
openai:
  api_key: "sk-..."
  base_url: "https://api.openai.com/v1"

# DeepSeek API
deepseek:
  api_key: "sk-..."
  base_url: "https://api.deepseek.com/v1"

# GLM-4.7-Flash API
glm:
  api_key: "..."
  base_url: "https://open.bigmodel.cn/api/paas/v4"

# 智谱AI API
zhipu:
  api_key: "..."
  base_url: "https://open.bigmodel.cn/api/paas/v4"

# 自定义API端点（如8094端口）
custom:
  api_key: "EMPTY"
  base_url: "http://REDACTED_INTERNAL_IP:8094/v1"
  model: "qwen3-30b-a3b"

# 默认使用哪个API
default_provider: "custom"
